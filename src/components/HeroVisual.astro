---
// Decorative 3D hero visual — an "agent constellation": a wireframe
// icosahedron with glowing vertex nodes, slowly rotating with subtle
// mouse parallax. Purely decorative + progressively enhanced: the page
// is fully usable with JS off (a CSS glow shows behind). three.js loads
// only on this page. Honors prefers-reduced-motion and pauses offscreen.
---

<div class="hero-visual" aria-hidden="true">
  <div class="visual-glow"></div>
  <canvas class="visual-canvas" data-hero-canvas></canvas>
</div>

<style>
  .hero-visual {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1 / 1;
    margin-inline: auto;
  }
  .visual-glow {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 45%,
      rgba(123, 106, 240, 0.28) 0%,
      rgba(72, 190, 166, 0.1) 38%,
      transparent 68%
    );
    filter: blur(6px);
  }
  .visual-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 860px) {
    .hero-visual {
      max-width: 300px;
    }
  }
</style>

<script>
  import * as THREE from "three";

  const canvas = document.querySelector<HTMLCanvasElement>("[data-hero-canvas]");
  const container = canvas?.parentElement;

  if (canvas && container instanceof HTMLElement) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.z = 3.7;

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });
    renderer.setClearColor(0x000000, 0);

    const violet = new THREE.Color(0x7b6af0);
    const teal = new THREE.Color(0x48bea6);

    const group = new THREE.Group();
    scene.add(group);

    // Outer wireframe icosahedron.
    const baseGeo = new THREE.IcosahedronGeometry(1.3, 1);
    const outer = new THREE.LineSegments(
      new THREE.WireframeGeometry(baseGeo),
      new THREE.LineBasicMaterial({
        color: violet,
        transparent: true,
        opacity: 0.5,
      }),
    );
    group.add(outer);

    // Glowing nodes at each unique vertex: a solid core sphere plus a
    // larger additive halo sphere for the glow.
    const coreGeo = new THREE.SphereGeometry(0.045, 14, 14);
    const coreMat = new THREE.MeshBasicMaterial({ color: 0xd8d2ff });
    const haloGeo = new THREE.SphereGeometry(0.1, 14, 14);
    const haloMat = new THREE.MeshBasicMaterial({
      color: teal,
      transparent: true,
      opacity: 0.4,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const pos = baseGeo.attributes.position;
    const seen = new Set<string>();
    for (let i = 0; i < pos.count; i++) {
      const x = pos.getX(i);
      const y = pos.getY(i);
      const z = pos.getZ(i);
      const key = `${x.toFixed(3)},${y.toFixed(3)},${z.toFixed(3)}`;
      if (seen.has(key)) continue;
      seen.add(key);
      const core = new THREE.Mesh(coreGeo, coreMat);
      core.position.set(x, y, z);
      group.add(core);
      const halo = new THREE.Mesh(haloGeo, haloMat);
      halo.position.set(x, y, z);
      group.add(halo);
    }

    // Inner counter-rotating frame for depth.
    const inner = new THREE.LineSegments(
      new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(0.72, 0)),
      new THREE.LineBasicMaterial({
        color: teal,
        transparent: true,
        opacity: 0.28,
      }),
    );
    group.add(inner);

    function resize() {
      const w = container!.clientWidth;
      const h = container!.clientHeight;
      if (!w || !h) return;
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    new ResizeObserver(resize).observe(container);

    let targetX = 0;
    let targetY = 0;
    let curX = 0;
    let curY = 0;
    window.addEventListener("pointermove", (e) => {
      targetX = e.clientX / window.innerWidth - 0.5;
      targetY = e.clientY / window.innerHeight - 0.5;
    });

    let raf = 0;
    function frame() {
      curX += (targetX - curX) * 0.05;
      curY += (targetY - curY) * 0.05;
      group.rotation.y += 0.0026;
      group.rotation.x = curY * 0.5;
      group.rotation.z = curX * 0.18;
      inner.rotation.y -= 0.0045;
      inner.rotation.x += 0.0025;
      renderer.render(scene, camera);
    }

    function loop() {
      frame();
      raf = requestAnimationFrame(loop);
    }

    if (reduce) {
      frame(); // single static render
    } else {
      const io = new IntersectionObserver((entries) => {
        const visible = entries[0]?.isIntersecting;
        if (visible && !raf) loop();
        else if (!visible && raf) {
          cancelAnimationFrame(raf);
          raf = 0;
        }
      });
      io.observe(container);
    }
  }
</script>
