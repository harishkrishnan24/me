---
import { href } from "../lib/links";

interface Props {
  id: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  draft?: boolean;
}
const { id, title, description, date, tags, draft } = Astro.props;
const dateLabel = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const isoDate = date.toISOString().slice(0, 10);
---

<a class="post-card reveal" href={href(`blog/${id}`)}>
  <div class="post-card-meta">
    <time datetime={isoDate}>{dateLabel}</time>
    {draft && <span class="draft">draft</span>}
  </div>
  <h3 class="post-card-title">{title}</h3>
  <p class="post-card-desc">{description}</p>
  {
    tags.length > 0 && (
      <div class="tag-row">
        {tags.slice(0, 3).map((t) => (
          <span class="tag">{t}</span>
        ))}
      </div>
    )
  }
  <span class="post-card-arrow">Read →</span>
</a>

<style>
  .post-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(22px, 3vw, 30px);
    transition:
      transform 0.22s var(--ease),
      border-color 0.22s var(--ease),
      background 0.22s var(--ease);
  }
  .post-card:hover {
    transform: translateY(-3px);
    border-color: var(--border-bright);
    border-left-color: var(--violet);
    background: var(--surface-2);
  }
  .post-card-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .draft {
    color: var(--orange);
  }
  .post-card-title {
    font-size: var(--step-1);
    margin-block: 12px 8px;
    color: var(--text);
  }
  .post-card:hover .post-card-title {
    color: var(--violet-soft);
  }
  .post-card-desc {
    font-family: var(--font-serif);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 18px;
  }
  .post-card-arrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--teal);
    display: inline-block;
    margin-top: 4px;
  }
  .post-card .tag-row {
    margin-bottom: 16px;
  }
</style>
