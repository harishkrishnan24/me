---
import { href } from "../lib/links";

interface Props {
  id: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  draft?: boolean;
}
const { id, title, description, date, tags, draft } = Astro.props;
const dateLabel = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const isoDate = date.toISOString().slice(0, 10);
---

<a class="post-entry reveal" href={href(`blog/${id}`)}>
  <div class="post-meta">
    <time datetime={isoDate}>{dateLabel}</time>
    {draft && <span class="draft">draft</span>}
  </div>
  <h3 class="post-title">{title}</h3>
  <p class="post-desc">{description}</p>
  {
    tags.length > 0 && (
      <div class="post-tags">
        {tags.slice(0, 3).map((t) => (
          <span class="tag">{t}</span>
        ))}
      </div>
    )
  }
</a>

<style>
  .post-entry {
    display: block;
    padding: clamp(22px, 3vw, 30px) 0;
    border-top: 1px solid var(--border);
    transition: border-color 0.2s var(--ease);
  }
  .post-entry:hover {
    border-top-color: var(--border-bright);
  }
  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .draft {
    color: var(--orange);
  }
  .post-title {
    font-size: var(--step-2);
    line-height: 1.15;
    margin-block: 10px 10px;
    color: var(--text);
    transition: color 0.18s var(--ease);
  }
  .post-entry:hover .post-title {
    color: var(--violet-soft);
  }
  .post-desc {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 60ch;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
</style>
