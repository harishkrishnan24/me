---
import { navLinks, href, isActive } from "../lib/links";
const pathname = Astro.url.pathname;
---

<header class="site-header">
  <nav class="wrap nav" aria-label="Primary">
    <a class="brand" href={href("")}>
      <span class="brand-mark">~/</span>harish<span class="brand-accent"
        >.dev</span
      >
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span><span></span>
    </button>
    <ul class="nav-links">
      {
        navLinks.map((link) =>
          link.external ? (
            <li>
              <a href={link.path} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            </li>
          ) : (
            <li>
              <a
                href={href(link.path)}
                aria-current={isActive(pathname, link.path) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ),
        )
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 14px;
  }
  .brand {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 15px;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .brand-mark {
    color: var(--violet);
  }
  .brand-accent {
    color: var(--text-dim);
  }
  .nav-links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .nav-links a {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 7px 12px;
    border-radius: var(--radius-sm);
    transition:
      color 0.15s var(--ease),
      background 0.15s var(--ease);
  }
  .nav-links a:hover {
    color: var(--text);
    background: var(--surface-2);
  }
  .nav-links a[aria-current="page"] {
    color: var(--violet);
    background: var(--violet-tint);
  }

  /* Mobile menu toggle (CSS-only via :focus-within fallback handled
     by the checkbox-free disclosure below); hidden on desktop. */
  .nav-toggle {
    display: none;
  }

  @media (max-width: 720px) {
    .nav {
      flex-wrap: wrap;
    }
    .nav-toggle {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 38px;
      height: 38px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .nav-toggle span {
      display: block;
      height: 2px;
      width: 18px;
      margin-inline: auto;
      background: var(--text-muted);
    }
    .nav-links {
      flex-basis: 100%;
      flex-direction: column;
      gap: 2px;
      display: none;
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links a {
      display: block;
    }
  }
</style>

<script>
  // Progressive enhancement: the menu toggle. Without JS, the nav
  // links render inline (no toggle needed on desktop); on mobile the
  // toggle simply reveals the already-present list. Content is never
  // hidden from crawlers or no-JS users on desktop widths.
  const toggle = document.querySelector(".nav-toggle");
  const links = document.querySelector(".nav-links");
  toggle?.addEventListener("click", () => {
    const open = links?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(Boolean(open)));
  });
</script>
