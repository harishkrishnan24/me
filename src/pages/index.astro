---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import HeroVisual from "../components/HeroVisual.astro";
import PostCard from "../components/PostCard.astro";
import { href } from "../lib/links";
import { sortByDateDesc, visiblePosts } from "../lib/posts";

const all = await getCollection("blog");
const latest = sortByDateDesc(visiblePosts(all, import.meta.env.DEV)).slice(0, 2);

const now = [
  "Building Usage Data solutions at DigitalRoute",
  "Going deep on Generative AI, ML & distributed systems",
  "Learning Go and Rust for efficient, scalable systems",
  "Writing essays and recording Udemy courses",
];
---

<BaseLayout title="Harish Krishnan">
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <Eyebrow accent="violet">Software Engineer · Stockholm</Eyebrow>
        <h1 class="hero-title">
          Engineering software, and rethinking how it's built in <span
            class="grad">the age of AI</span
          >.
        </h1>
        <p class="hero-deck">
          Engineer at DigitalRoute, course instructor, and writer. I care about
          systems that are fast, correct, and a pleasure to use — and about what
          changes when AI becomes part of how we build them.
        </p>

        <div class="cta-row">
          <a class="btn" href={href("blog")}>Read the writing →</a>
          <a class="btn ghost" href={href("about")}>About me</a>
        </div>

        <nav class="hero-socials" aria-label="Social links">
          <a
            href="https://github.com/harishkrishnan24"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <a
            href="https://www.linkedin.com/in/harishkrishnan1993/"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <a
            href="https://x.com/harishkforu"
            target="_blank"
            rel="noopener noreferrer">X</a
          >
        </nav>
      </div>

      <HeroVisual />
    </div>
  </section>

  <div class="wrap"><div class="divider"></div></div>

  <!-- CURRENTLY -->
  <section class="wrap two-col">
    <div class="col-head reveal">
      <Eyebrow accent="teal">Now</Eyebrow>
      <h2>What I'm working on</h2>
    </div>
    <ul class="now-list reveal">
      {now.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <div class="wrap"><div class="divider"></div></div>

  <!-- LATEST WRITING -->
  <section class="wrap latest">
    <div class="latest-head reveal">
      <Eyebrow accent="violet">Latest writing</Eyebrow>
      <a class="see-all" href={href("blog")}>All posts →</a>
    </div>
    {
      latest.length > 0 ? (
        <div class="latest-grid">
          {latest.map((p) => (
            <PostCard
              id={p.id}
              title={p.data.title}
              description={p.data.description}
              date={p.data.date}
              tags={p.data.tags}
              draft={p.data.draft}
            />
          ))}
        </div>
      ) : (
        <p class="muted">First post coming soon.</p>
      )
    }
  </section>

  <div class="wrap"><div class="divider"></div></div>

  <!-- CONTACT -->
  <section class="wrap contact">
    <div class="contact-intro reveal">
      <Eyebrow accent="orange">Get in touch</Eyebrow>
      <h2>Let's talk.</h2>
      <p class="muted">
        Open to conversations about engineering, AI systems, collaboration — or
        just connecting with fellow developers.
      </p>
      <ul class="contact-links">
        <li>
          <span class="k">email</span>
          <a href="mailto:harishkrishnan1993@gmail.com"
            >harishkrishnan1993@gmail.com</a
          >
        </li>
        <li>
          <span class="k">github</span>
          <a
            href="https://github.com/harishkrishnan24"
            target="_blank"
            rel="noopener noreferrer">@harishkrishnan24</a
          >
        </li>
        <li>
          <span class="k">linkedin</span>
          <a
            href="https://www.linkedin.com/in/harishkrishnan1993/"
            target="_blank"
            rel="noopener noreferrer">in/harishkrishnan1993</a
          >
        </li>
        <li>
          <span class="k">x</span>
          <a
            href="https://x.com/harishkforu"
            target="_blank"
            rel="noopener noreferrer">@harishkforu</a
          >
        </li>
      </ul>
    </div>

    <form
      class="contact-form card violet reveal"
      action="mailto:harishkrishnan1993@gmail.com"
      method="post"
      enctype="text/plain"
    >
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" required maxlength="100" />
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required maxlength="100" />
      </div>
      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required></textarea>
      </div>
      <button class="btn" type="submit">Send message →</button>
      <p class="form-note">Opens your email client — no data leaves your device.</p>
    </form>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.82fr);
    gap: clamp(24px, 5vw, 72px);
    align-items: center;
    min-height: min(78vh, 660px);
    padding-block: clamp(28px, 5vw, 56px);
  }
  .hero-copy {
    max-width: 600px;
  }
  .hero-title {
    font-size: clamp(38px, 5vw, 66px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.035em;
    text-wrap: balance;
    margin-block: 22px 22px;
  }
  .grad {
    background: linear-gradient(100deg, var(--violet), var(--teal));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-deck {
    font-size: var(--step-1);
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 34em;
    margin-bottom: 30px;
  }
  .hero-socials {
    display: flex;
    gap: 20px;
    margin-top: 26px;
  }
  .hero-socials a {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    transition: color 0.15s var(--ease);
  }
  .hero-socials a:hover {
    color: var(--teal);
  }
  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      min-height: 0;
      gap: 20px;
      padding-block: 24px 8px;
    }
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .btn.ghost {
    background: transparent;
    border-color: var(--border-bright);
    color: var(--text-muted);
  }
  .btn.ghost:hover {
    color: var(--text);
    border-color: var(--text-muted);
    background: var(--surface-2);
  }

  /* Two-column section */
  .two-col,
  .contact {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: start;
  }
  .col-head h2,
  .latest-head + * ,
  .contact-intro h2 {
    font-size: var(--step-2);
  }
  .col-head h2 {
    font-size: var(--step-2);
    margin-top: 10px;
  }
  .now-list {
    list-style: none;
    display: grid;
    gap: 14px;
  }
  .now-list li {
    position: relative;
    padding-left: 26px;
    color: var(--text);
    line-height: 1.5;
  }
  .now-list li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--teal);
    font-family: var(--font-mono);
  }

  /* Latest */
  .latest {
    display: block;
  }
  .latest-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 22px;
  }
  .see-all {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--teal);
  }
  .latest-grid {
    max-width: var(--measure);
  }

  /* Contact */
  .contact-intro h2 {
    margin-block: 10px 14px;
  }
  .muted {
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 34em;
  }
  .contact-links {
    list-style: none;
    margin-top: 24px;
    display: grid;
    gap: 12px;
  }
  .contact-links li {
    display: flex;
    gap: 14px;
    align-items: baseline;
  }
  .contact-links .k {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    min-width: 72px;
  }
  .contact-links a {
    color: var(--text);
    border-bottom: 1px solid transparent;
  }
  .contact-links a:hover {
    color: var(--teal);
    border-bottom-color: var(--teal-line);
  }

  /* Form */
  .contact-form {
    display: grid;
    gap: 16px;
  }
  .field {
    display: grid;
    gap: 6px;
  }
  .field label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .field input,
  .field textarea {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    color: var(--text);
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--violet);
  }
  .form-note {
    font-size: var(--step--1);
    color: var(--text-dim);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .two-col,
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>
