    url: "https://github.com/javascript-tutorial/en.javascript.info/pull/3598",
  },
  {
    project: "prisma",
    type: "Bug",
    contribution: "Raised a bug",
    status: "Acknowledged",
    url: "https://github.com/prisma/prisma/issues/26021",
  },
  {
    project: "bulletproof-react",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/alan2207/bulletproof-react/pull/224",
  },
  {
    project: "apollo-client",
    type: "Documentation",
    contribution: "Fixed example error",
    status: "Merged",
    url: "https://github.com/apollographql/apollo-client/pull/11998",
  },
  {
    project: "angular",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/angular/angular/pull/56819",
  },
  {
    project: "angular",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/angular/angular/pull/56921",
  },
  {
    project: "angular",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/angular/angular/pull/56753",
  },
  {
    project: "qwik",
    type: "Documentation",
    contribution: "Fixed bug in links",
    status: "Merged",
    url: "https://github.com/QwikDev/qwik/pull/5445",
  },
  {
    project: "qwik",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/QwikDev/qwik/pull/5446",
  },
  {
    project: "qwik",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/QwikDev/qwik/pull/5444",
  },
  {
    project: "qwik",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/QwikDev/qwik/pull/4862",
  },
  {
    project: "qwik",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/QwikDev/qwik/pull/4885",
  },
  {
    project: "qwik",
    type: "Documentation",
    contribution: "Fixed typo",
    status: "Merged",
    url: "https://github.com/QwikDev/qwik/pull/4866",
  },
  {
    project: "qwik",
    type: "Documentation",
