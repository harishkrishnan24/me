---
import BaseLayout from "../layouts/BaseLayout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import { href } from "../lib/links";

// Repositories I've contributed to, grouped by kind. Each card links to
// the project's source. Data lives here so the markup stays a simple map.
interface Repo {
  name: string;
  url: string;
  description: string;
  tags: string[];
}
interface RepoGroup {
  label: string;
  accent: "violet" | "orange" | "teal";
  repos: Repo[];
}

const repoGroups: RepoGroup[] = [
  {
    label: "Package Libraries",
    accent: "violet",
    repos: [
      {
        name: "Prisma",
        url: "https://github.com/prisma/prisma",
        description: "ORM for Node.js and TypeScript.",
        tags: ["TypeScript", "ORM"],
      },
      {
        name: "Apollo Client",
        url: "https://github.com/apollographql/apollo-client",
        description: "GraphQL client for React and other frameworks.",
        tags: ["GraphQL", "React"],
      },
      {
        name: "Angular",
        url: "https://github.com/angular/angular",
        description:
          "A platform for building mobile and desktop web applications.",
        tags: ["TypeScript", "Framework"],
      },
      {
        name: "Qwik",
        url: "https://github.com/QwikDev/qwik",
        description:
          "A new web framework for building fast, optimized applications.",
        tags: ["TypeScript", "Framework"],
      },
    ],
  },
  {
    label: "Open Source Learning Sites",
    accent: "teal",
    repos: [
      {
        name: "JavaScript.info",
        url: "https://javascript.info/",
        description: "Open source JavaScript tutorials and resources.",
        tags: ["JavaScript", "Docs"],
      },
      {
        name: "Zig Guide",
        url: "https://github.com/Sobeston/zig.guide",
        description:
          "Open source Zig programming language tutorials and resources.",
        tags: ["Zig", "Docs"],
      },
    ],
  },
  {
    label: "Developer Tools",
    accent: "orange",
    repos: [
      {
        name: "Bulletproof React",
        url: "https://github.com/alan2207/bulletproof-react",
        description:
          "A collection of best practices for building React applications.",
        tags: ["React", "Best Practices"],
      },
    ],
  },
];

// Individual merged/closed contributions, preserved verbatim from the
