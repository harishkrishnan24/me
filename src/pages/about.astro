---
import BaseLayout from "../layouts/BaseLayout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import { href } from "../lib/links";

const languages = ["JavaScript / TypeScript", "Python", "Go", "Rust"];

interface Tech {
  label: string;
  learning?: boolean;
}
const tech: Tech[] = [
  { label: "React" },
  { label: "Angular" },
  { label: "Vue.js" },
  { label: "Svelte", learning: true },
  { label: "Node.js" },
  { label: "Express" },
  { label: "NestJS" },
  { label: "React Native", learning: true },
  { label: "Docker" },
  { label: "Kubernetes" },
  { label: "AWS" },
  { label: "MongoDB" },
  { label: "PostgreSQL" },
  { label: "GraphQL", learning: true },
  { label: "gRPC", learning: true },
  { label: "Cypress" },
  { label: "Protractor" },
  { label: "Jest" },
  { label: "Vitest" },
  { label: "React Testing Library" },
  { label: "Redux" },
  { label: "NgRx" },
  { label: "VueX" },
  { label: "AWS SageMaker", learning: true },
  { label: "Crew AI", learning: true },
  { label: "LangGraph", learning: true },
  { label: "LangChain", learning: true },
  { label: "MCP", learning: true },
