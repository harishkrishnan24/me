    company: "DigitalRoute",
    duration: "Current Position",
    location: "Stockholm, Sweden",
    description: "Currently working on building robust Usage Data solutions.",
    technologies: [
      "React",
      "Node.js",
      "Express.js",
      "JavaScript",
      "TypeScript",
      "HTML",
      "CSS",
      "StoryBook",
      "Redux",
      "AWS Services",
      "AWS SageMaker",
      "Jest",
      "Vitest",
      "React Testing Library",
      "Playwright",
    ],
    bullets: [
      "Building scalable web applications using modern technologies such as React and Node.js",
      "Integrating AI/ML and LLM solutions",
    ],
  },
  {
    accent: "teal",
    title: "Course Instructor (during my free time)",
    company: "Udemy",
    duration: "June 2023 — Present",
    location: "Remote",
    description:
      "Creating courses on the Udemy platform, focusing on software development, programming languages, and modern web technologies.",
    technologies: ["JavaScript", "TypeScript", "React", "Node.js", "Go", "Rust"],
    bullets: [
      "Created six courses with over a thousand students enrolled",
      "Maintain a rating of 4+ out of five across more than 50 reviews",
    ],
  },
  {
    accent: "orange",
    title: "Software Engineer",
    company: "SAP Labs",
    duration: "Nov 2020 — Jan 2024",
    location: "Bengaluru, India",
    description:
      "Worked on enterprise software solutions, contributing to large-scale applications used by businesses worldwide using Angular, React, Node.js, Spring Boot, and more.",
    technologies: [
      "Angular",
      "React",
      "Node.js",
      "Spring Boot",
      "Java",
      "TypeScript",
      "JavaScript",
      "HTML",
      "CSS",
      "SAPUI5",
      "SAP CAP",
      "SAP BTP",
      "Jenkins",
      "Go",
      "Protractor",
      "DevOps",
      "Security",
    ],
    bullets: [
      "Developed enterprise-grade software applications for Real Estate and Human Resource",
      "Awarded three times for effective contribution to the team",
    ],
  },
  {
    accent: "violet",
    title: "Front-end Developer",
    company: "Fragma Data Systems",
    duration: "Jul 2020 — Nov 2020",
    location: "Remote",
    description:
      "Contributed to UI development of multiple projects, for a bank called Mashreq in the UAE and a state government project.",
    technologies: [
      "React",
      "JavaScript",
      "TypeScript",
      "CSS",
      "HTML",
      "Redux",
      "Jest",
      "React Testing Library",
    ],
    bullets: ["Developed UI solutions using React and its ecosystem"],
  },
  {
    accent: "teal",
    title: "Full Stack Developer",
    company: "FoodDocs (Contractor)",
    duration: "May 2017 — Mar 2020",
    location: "Remote",
    description: "Worked on building a food safety management system.",
    technologies: [
      "Angular",
      "Vue.js",
      "Laravel",
      "MySQL",
      "Cypress",
      "Flutter",
