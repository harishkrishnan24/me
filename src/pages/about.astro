  {
    accent: "violet",
    title: "Freelance Developer",
    company: "Upwork",
    duration: "May 2017 — Dec 2018",
    location: "Remote",
    description:
      "Worked as a freelance developer on a real estate project, focusing on UI development and client collaboration to deliver high-quality web applications.",
    technologies: [
      "Angular",
      "TypeScript",
      "JavaScript",
      "HTML",
      "CSS",
      "NgRx Store",
    ],
    bullets: [
      "Actively contributed to UI development using Angular — building reusable components, setting up projects from scratch, and more",
      "Worked hand-in-hand with the owner of the idea to improve the product UI flow",
      "Involved in the recruitment of new people",
      "Communicated with the back-end developer, providing suggestions and integrating the UI with the back-end",
    ],
  },
  {
    accent: "teal",
    title: "Software Engineer",
    company: "Squash Apps",
    duration: "Sep 2016 — May 2017",
    location: "Coimbatore, India",
    description:
      "Started as an entry-level software engineer and quickly developed full-stack development skills, contributing to in-house products and client projects.",
    technologies: [
      "MongoDB",
      "Express.js",
      "React",
      "Node.js (MERN Stack)",
      "Ionic",
    ],
    bullets: [
      "Joined as an entry-level software engineer",
      "Quickly ramped up with MERN stack skills within a month",
      "Actively contributed to in-house products, leading to an opportunity to work with US-based clients",
