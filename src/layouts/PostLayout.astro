---
import BaseLayout from "./BaseLayout.astro";
import Eyebrow from "../components/Eyebrow.astro";
import { href } from "../lib/links";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  draft?: boolean;
}
const { title, description, date, tags, draft } = Astro.props;

const dateLabel = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const isoDate = date.toISOString().slice(0, 10);

// Share targets — absolute URL is required.
const postUrl = new URL(Astro.url.pathname, Astro.site).href;
const shareX = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`;
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={date}
  tags={tags}
>
  <article class="wrap post">
    <a class="back" href={href("blog")}>← Writing</a>

    <header class="post-hero reveal">
      <Eyebrow accent="violet">
        <time datetime={isoDate}>{dateLabel}</time>
        {draft && <span class="draft-flag">· draft</span>}
      </Eyebrow>
      <h1 class="post-title">{title}</h1>
      <p class="post-deck">{description}</p>
      <div class="rule"></div>
    </header>

    <div class="prose reveal">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <div class="tag-row post-tags">
          {tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
      )
    }

    <footer class="share">
      <span class="share-label">Share</span>
      <a
        class="share-btn"
        href={shareX}
        target="_blank"
        rel="noopener noreferrer">X / Twitter</a
      >
      <a
        class="share-btn"
        href={shareLinkedIn}
        target="_blank"
        rel="noopener noreferrer">LinkedIn</a
      >
      <button class="share-btn copy-link" data-url={postUrl} type="button">
        Copy link
      </button>
    </footer>
  </article>
</BaseLayout>

<script>
  // Progressive enhancement: copy-to-clipboard. Without JS the X/LinkedIn
  // links still work; only this button is inert.
  const btn = document.querySelector<HTMLButtonElement>(".copy-link");
  btn?.addEventListener("click", async () => {
    const url = btn.dataset.url;
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const original = btn.textContent;
      btn.textContent = "Copied ✓";
      setTimeout(() => (btn.textContent = original), 1600);
    } catch {
      // clipboard unavailable — no-op
    }
  });
</script>

<style>
  .post {
    max-width: var(--measure);
  }
  .back {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    display: inline-block;
    margin-bottom: 40px;
    transition: color 0.15s var(--ease);
  }
  .back:hover {
    color: var(--teal);
  }
  .post-hero {
    position: relative;
    margin-bottom: 44px;
  }
  .post-title {
    font-size: var(--step-4);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-block: 20px 18px;
  }
  .post-deck {
    font-size: var(--step-1);
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.55;
    max-width: 36em;
    margin-bottom: 28px;
  }
  .draft-flag {
    color: var(--orange);
  }
  .post-tags {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .share {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
  .share-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-right: 4px;
  }
  .share-btn {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    cursor: pointer;
    transition:
      color 0.15s var(--ease),
      border-color 0.15s var(--ease);
  }
  .share-btn:hover {
    color: var(--teal);
    border-color: var(--teal-line);
  }
</style>
